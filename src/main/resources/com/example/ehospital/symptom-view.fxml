<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.ehospital.SymptomController"
      stylesheets="@styles.css">

    <!-- SIDEBAR -->
    <VBox styleClass="sidebar" spacing="3">
        <HBox alignment="CENTER_LEFT" spacing="11">
            <Label text="+" styleClass="sidebar-logo"/>
            <Label text="Ranmdy" styleClass="sidebar-brand"/>
        </HBox>
        <Region prefHeight="20"/>

        <Button text="Dashboard" styleClass="nav-item" maxWidth="Infinity" onAction="#goToDashboard"/>
        <Button text="Symptom check" styleClass="nav-item-active" maxWidth="Infinity"/>
        <Button text="Consultation" styleClass="nav-item" maxWidth="Infinity"/>
        <Button text="Prescription" styleClass="nav-item" maxWidth="Infinity"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-divider" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="11">
                <Label fx:id="avatarLabel" styleClass="avatar, avatar-blue"/>
                <VBox>
                    <Label fx:id="userNameLabel" styleClass="sidebar-user-name"/>
                    <Label text="Patient" styleClass="sidebar-user-sub"/>
                </VBox>
            </HBox>
            <Button text="Log out" styleClass="btn-logout" onAction="#onLogout"/>
        </VBox>
    </VBox>

    <!-- MAIN -->
    <VBox HBox.hgrow="ALWAYS">
        <!-- TOPBAR -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <VBox>
                <Label text="Symptom check" styleClass="topbar-title"/>
                <Label text="Describe what you are feeling" styleClass="topbar-sub"/>
            </VBox>
        </HBox>

        <!-- CONTENT -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F4F1EC; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox styleClass="content-area" spacing="18" maxWidth="680">
                <VBox styleClass="card" spacing="14">
                    <Label text="DESCRIBE YOUR SYMPTOMS" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #8A8F94;"/>
                    <Label text="Tell us how you are feeling. Be as detailed as possible — mention body parts, duration, and severity." style="-fx-font-size: 14; -fx-text-fill: #6B6F76;" wrapText="true"/>
                    <TextArea fx:id="symptomArea" promptText="e.g. I have had a persistent cough for 3 days with mild fever and difficulty breathing at night..."
                              prefRowCount="5" wrapText="true" styleClass="text-input" style="-fx-pref-height: 120;"/>

                    <!-- Classification chip -->
                    <HBox fx:id="classChip" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false">
                        <Label text="Classification:" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #4A4F57;"/>
                        <Label fx:id="classLabel" styleClass="status-available" text=""/>
                        <Label text="→" style="-fx-text-fill: #8A8F94;"/>
                        <Label fx:id="specialtyLabel" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #1F4D8F;" text=""/>
                    </HBox>

                    <HBox spacing="12">
                        <Button text="Classify" styleClass="btn-primary" style="-fx-background-color: #EDEAE2; -fx-text-fill: #4A4F57;" onAction="#onClassify"/>
                        <Button fx:id="submitBtn" text="Submit to doctor →" styleClass="btn-primary" onAction="#onSubmit" disable="true"/>
                    </HBox>

                    <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
                </VBox>

                <!-- Info card -->
                <VBox styleClass="card" spacing="8">
                    <Label text="HOW IT WORKS" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #8A8F94;"/>
                    <Label text="1. Describe your symptoms in the box above" style="-fx-font-size: 14; -fx-text-fill: #3A3F47;"/>
                    <Label text="2. Click Classify to see which illness category matches" style="-fx-font-size: 14; -fx-text-fill: #3A3F47;"/>
                    <Label text="3. Submit to get matched with an available specialist" style="-fx-font-size: 14; -fx-text-fill: #3A3F47;"/>
                    <Label text="4. Wait for the doctor to accept your consultation" style="-fx-font-size: 14; -fx-text-fill: #3A3F47;"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
