<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefHeight="900" prefWidth="1500" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.ehospital.SymptomController"
      stylesheets="@styles.css">

    <!-- SIDEBAR -->
    <VBox styleClass="sidebar" spacing="3">
        <HBox alignment="CENTER_LEFT" spacing="11">
            <Label text="+" styleClass="sidebar-logo"/>
            <Label text="E-Healthcare Management" styleClass="sidebar-brand"/>
        </HBox>
        <Region prefHeight="20"/>

        <Button text="Dashboard" styleClass="nav-item" maxWidth="Infinity" onAction="#goToDashboard"/>
        <Button text="Symptom check" styleClass="nav-item-active" maxWidth="Infinity"/>
        <Button text="Consultation" styleClass="nav-item" maxWidth="Infinity" onAction="#goToConsultation"/>
        <Button text="Prescription" styleClass="nav-item" maxWidth="Infinity" onAction="#goToPrescription"/>

        <Region VBox.vgrow="ALWAYS"/>

        <VBox styleClass="sidebar-divider" spacing="8">
            <HBox alignment="CENTER_LEFT" spacing="11">
                <Label fx:id="avatarLabel" styleClass="avatar, avatar-blue"/>
                <VBox>
                    <Label fx:id="userNameLabel" styleClass="sidebar-user-name"/>
                    <Label text="Patient" styleClass="sidebar-user-sub"/>
                </VBox>
            </HBox>
            <Button text="Log out" styleClass="btn-logout" onAction="#onLogout"/>
        </VBox>
    </VBox>

    <!-- MAIN -->
    <VBox HBox.hgrow="ALWAYS">
        <!-- TOPBAR -->
        <HBox styleClass="topbar" alignment="CENTER_LEFT">
            <VBox>
                <Label text="Symptom check" styleClass="topbar-title"/>
                <Label text="Describe what you are feeling" styleClass="topbar-sub"/>
            </VBox>
        </HBox>

        <!-- CONTENT -->
        <ScrollPane fitToWidth="true" style="-fx-background-color: #F4F1EC; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
            <VBox styleClass="content-area" spacing="18" maxWidth="760">
                <VBox styleClass="card" spacing="14" style="-fx-padding: 26;">
                    <Label text="What are you experiencing?" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1A1C20;"/>
                    <Label text="Describe your symptoms in your own words. We'll classify the illness and route you to a specialist." style="-fx-font-size: 14; -fx-text-fill: #8A8F94;" wrapText="true"/>
                    <TextArea fx:id="symptomArea" promptText="e.g. dry cough, fever, trouble breathing..."
                              prefRowCount="5" wrapText="true" styleClass="text-input" style="-fx-pref-height: 140;"/>

                    <!-- Auto-classified result box -->
                    <VBox style="-fx-background-color: #F3F7FD; -fx-border-color: #D7E3F4; -fx-border-radius: 13; -fx-background-radius: 13; -fx-padding: 16 18;" spacing="10">
                        <Label text="AUTO-CLASSIFIED RESULT" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #6E84A8;"/>
                        <HBox fx:id="classChip" spacing="8" alignment="CENTER_LEFT" visible="false" managed="false">
                            <Label fx:id="classLabel" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: white; -fx-background-color: #1F4D8F; -fx-background-radius: 20; -fx-padding: 7 14;"/>
                            <Label text="&#x2192;" style="-fx-text-fill: #8A8F94; -fx-font-size: 16;"/>
                            <Label fx:id="specialtyLabel" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #1F4D8F; -fx-background-color: white; -fx-background-radius: 20; -fx-padding: 6 14; -fx-border-color: #1F4D8F; -fx-border-radius: 20; -fx-border-width: 1.5;"/>
                        </HBox>
                        <Label fx:id="classHint" text="Click Classify or start typing to see the matched specialty." style="-fx-font-size: 13; -fx-text-fill: #8A9ABA;"/>
                    </VBox>

                    <HBox spacing="12">
                        <Button text="Classify" styleClass="btn-primary" style="-fx-background-color: #EDEAE2; -fx-text-fill: #4A4F57;" onAction="#onClassify"/>
                    </HBox>

                    <Button fx:id="submitBtn" text="Submit &amp; start consultation" styleClass="btn-primary" maxWidth="Infinity" onAction="#onSubmit" disable="true"/>

                    <Label fx:id="messageLabel" styleClass="error-label" wrapText="true"/>
                    <Label fx:id="queueHint" text="" style="-fx-font-size: 12; -fx-text-fill: #9A9EA5; -fx-alignment: center;" alignment="CENTER" visible="false" managed="false"/>
                </VBox>
            </VBox>
        </ScrollPane>
    </VBox>
</HBox>
